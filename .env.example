# Supabase project URL (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (Project Settings -> API -> Publishable key)
# Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role / secret key (Project Settings -> API -> Service role key)
# SERVER ONLY. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# [PLACEHOLDER] WhatsApp business number in international format, digits only (no + or spaces)
# e.g. 94771234567
NEXT_PUBLIC_WHATSAPP_NUMBER=

NEXT_PUBLIC_SITE_NAME="Lanka Commercial Motors"
